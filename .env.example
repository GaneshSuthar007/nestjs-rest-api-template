# Application
NODE_ENV=development
APP_PORT=3000

# Security
# Every request must send this value in the `x-api-key` header
API_KEY=change-me-strong-api-key
JWT_SECRET=change-me-super-secret-jwt-key
JWT_EXPIRES_IN=7d

# Database (used by both the app and the Prisma CLI)
DATABASE_URL="mysql://root:password@localhost:3306/nestjs_template"
